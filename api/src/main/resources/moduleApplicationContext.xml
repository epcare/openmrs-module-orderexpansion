<!-- Beans to add to the current Application context definition -->

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
			    http://www.springframework.org/schema/beans/spring-beans.xsd">


    <!-- OrderExpansion Service - Wraps methods in DB transactions and OpenMRS interceptors,
    which set audit info like dateCreated, changedBy, etc.-->

    <bean id="orderExpansionService"
          class="org.springframework.transaction.interceptor.TransactionProxyFactoryBean">
        <property name="transactionManager" ref="transactionManager"/>
        <property name="target">
            <bean class="org.openmrs.module.orderexpansion.api.impl.OrderExpansionServiceImpl">
                <property name="dao" ref="orderExpansionDao"/>
            </bean>
        </property>
        <property name="preInterceptors" ref="serviceInterceptors"/>
        <property name="transactionAttributeSource" ref="transactionAttributeSource"/>
    </bean>

    <bean id="orderExpansionDao" class="org.openmrs.module.orderexpansion.api.dao.impl.OrderExpansionDaoImpl">
        <property name="sessionFactory" ref="sessionFactory"/>
    </bean>

    <bean parent="serviceContext">
        <property name="moduleService">
            <list>
                <value>org.openmrs.module.orderexpansion.api.OrderExpansionService</value>
                <ref bean="orderExpansionService"/>
            </list>
        </property>
    </bean>

</beans>